# ─── Open Event – Shared Configuration ───────────────────────────────────────
# Copy this file to .env, fill in your values, then run:
#   python3 setup.py
#
# This propagates shared values into each repo's config files:
#   open-event-organizer-android  →  app/build.gradle, network_security_config.xml
#   open-event-frontend           →  .env
#   open-event-server             →  .env

# Server host reachable from your Android device/emulator and browser.
# Use your machine's LAN IP (not 'localhost') so the Android app can connect.
SERVER_HOST=192.168.100.125
SERVER_PORT=8080

# PostgreSQL – used by open-event-server
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=open_event_user
POSTGRES_PASSWORD=opev_pass
POSTGRES_DB=open_event

# Flask secret key – generate a fresh one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Mapbox – used by the Android app and the frontend
MAPBOX_ACCESS_TOKEN=

# Sentry – optional, used by all three repos (leave blank to disable)
SENTRY_DSN=

# Initial superuser created when running setup.py --start
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─── KHSC Integration ─────────────────────────────────────────────────────────
# Credentials for https://khsc.site/api/index.php
# Mock values below match khsc_mock/mock_server.py — replace with real keys from
# the KHSC admin before going to production. See API_Documentation_KHSC.docx.
KHSC_API_URL=http://localhost:9090/api/index.php
KHSC_API_USERNAME=admin_desk_1
KHSC_AUTHORIZATION=Bearer tok_test_khsc_mock_2026
KHSC_PASS_KEY=pk_test_khsc_mock_2026
KHSC_SECRET_KEY=sk_test_khsc_mock_2026
